# ─── Desenvolvimento: Create React App com hot reload ────────
FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY public ./public
COPY src ./src

EXPOSE 8080

ENV HOST=0.0.0.0
ENV PORT=8080
ENV CHOKIDAR_USEPOLLING=true
ENV WDS_SOCKET_PORT=8080
ENV CI=true

CMD ["npm", "start"]
